DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scilent_x?schema=public"
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://127.0.0.1:3000"
# Optional: comma-separated user IDs treated as admins (bootstrap before seed)
# BETTER_AUTH_ADMIN_USER_IDS=

# TIDAL
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_COUNTRY_CODE=

# SPOTIFY
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# APPLE MUSIC (MusicKit developer token)
# Team ID (Apple Developer Membership) and MusicKit Key ID from the developer portal.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
# Full PEM contents of the downloaded .p8 key. A single-line value with escaped
# newlines (\n) between the header/body/footer is supported.
APPLE_MUSIC_PRIVATE_KEY=
# Optional default catalog storefront (defaults to "us").
APPLE_MUSIC_STOREFRONT=
