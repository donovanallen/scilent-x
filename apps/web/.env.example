# =============================================================================
# apps/web — environment template
# Copy to `.env.local` for local Next.js (never commit secrets).
# On Vercel: set the same keys in Project → Settings → Environment Variables
# (Production / Preview / Development as appropriate).
#
# Canonical schema: `src/env.ts` (validated at build + boot via @t3-oss/env-nextjs).
# Set SKIP_ENV_VALIDATION=true only for tooling that must run without secrets.
# =============================================================================

# --- Required -----------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scilent_x?schema=public"

# Generate with: openssl rand -base64 32  (must be ≥32 characters)
BETTER_AUTH_SECRET="your-secret-here-at-least-32-chars!!"

# Canonical app origin (no trailing slash). Use 127.0.0.1 locally to match cookies.
BETTER_AUTH_URL="http://127.0.0.1:3000"

# --- Optional (public / platform) ---------------------------------------------
# Prefer this for SEO metadata when it differs from BETTER_AUTH_URL.
# NEXT_PUBLIC_APP_URL="http://127.0.0.1:3000"

# Set automatically by Vercel — do not set locally unless testing that path.
# VERCEL_URL=

# fatal | error | warn | info | debug | trace (default: debug in dev, info in prod)
# LOG_LEVEL=info

# MusicBrainz User-Agent contact (email). Defaults to an example if unset.
# MUSICBRAINZ_CONTACT="you@example.com"

# Optional bootstrap: comma-separated user IDs treated as admins before seed.
# BETTER_AUTH_ADMIN_USER_IDS=

# --- Optional: production admin seed (`pnpm db:seed` from packages/db) --------
# Used by Prisma seed only (not read by the Next.js app). In production
# (NODE_ENV=production or VERCEL_ENV=production), seed creates/updates a single
# admin credential account and requires both email + password.
# SEED_ADMIN_EMAIL="admin@yourdomain.com"
# SEED_ADMIN_PASSWORD="use-a-long-random-secret"
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_NAME="Scilent Admin"

# --- Optional: Spotify (OAuth link + catalog) ---------------------------------
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI="http://127.0.0.1:3000/api/auth/callback/spotify"

# --- Optional: Tidal ----------------------------------------------------------
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=
# TIDAL_COUNTRY_CODE=US

# --- Optional: Apple Music (MusicKit developer token) -------------------------
# Team ID (Apple Developer Membership) and MusicKit Key ID from the portal.
# APPLE_MUSIC_TEAM_ID=
# APPLE_MUSIC_KEY_ID=
# Full PEM of the .p8 key; single-line with escaped newlines (\n) is supported.
# APPLE_MUSIC_PRIVATE_KEY=
# Optional default catalog storefront (defaults to "us").
# APPLE_MUSIC_STOREFRONT=us

# --- Optional: social login (disabled in auth config; admin status UI only) ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# --- Optional: auth email (Resend) — password reset + verification ------------
# Without RESEND_API_KEY, reset/verification endpoints no-op (logged warn).
# RESEND_API_KEY=
# AUTH_EMAIL_FROM="Scilent <noreply@yourdomain.com>"

# --- Optional: Sentry (error monitoring) --------------------------------------
# Leave unset locally / in CI — SDK stays disabled when no DSN is present.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# Source-map upload (build/CI only; never commit):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- Optional: Prisma pool sizing (read by @scilent-one/db) -------------------
# Cap pg pool connections per serverless instance (prod default: 5 if unset).
# DATABASE_POOL_MAX=5
