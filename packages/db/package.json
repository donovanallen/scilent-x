{
  "name": "@scilent-one/db",
  "version": "0.6.1",
  "private": true,
  "description": "Prisma database client for the monorepo",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scilent-one/logger": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@scilent-one/tooling": "workspace:*",
    "@types/node": "^26.1.0",
    "better-auth": "catalog:better-auth",
    "prisma": "catalog:prisma",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
