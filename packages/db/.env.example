# Used by Prisma CLI (`pnpm db:*` from packages/db) and seed scripts.
# The Next app (`apps/web`) uses the same DATABASE_URL via apps/web/.env.local.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scilent_x?schema=public"

# --- Seed (pnpm db:seed) ------------------------------------------------------
# Local / non-production: seeds admin + mock users (alice/bob/carol).
# Default local password is password123 unless overridden.
# SEED_USER_PASSWORD="password123"

# Production (NODE_ENV=production or VERCEL_ENV=production): seeds ONLY the admin
# account. Both email and password are required — no weak defaults.
# SEED_ADMIN_EMAIL="admin@yourdomain.com"
# SEED_ADMIN_PASSWORD="use-a-long-random-secret"
# Optional aliases / overrides:
# SEED_USER_PASSWORD=            # password fallback if SEED_ADMIN_PASSWORD unset
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_NAME="Scilent Admin"

# Optional: cap pg Pool max connections (production default in client: 5 if unset)
# DATABASE_POOL_MAX=5
