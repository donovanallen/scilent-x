// Prisma Schema for Better Auth
// https://pris.ly/d/prisma-schema
// https://www.better-auth.com/docs/adapters/prisma

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Better Auth Core Models
// ============================================================================

/// User model - Core user information with social profile fields
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Social profile fields
  // Username is auto-generated on signup (format: u_<hex>) and can be changed by user later
  // Kept as nullable for backwards compatibility, but always set by auth hooks
  username      String?   @unique
  bio           String?   @db.Text
  avatarUrl     String?

  // UI preferences
  // Selected color palette (theme preset); mode (light/dark) is client-only.
  palette       String    @default("default")

  // Profile type — user role/verification status
  profileType   ProfileType @default(USER)

  // Better Auth admin plugin fields
  // https://www.better-auth.com/docs/plugins/admin#schema
  role          String?   @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  // Auth relations
  accounts Account[]
  sessions Session[]

  // Social relations
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  reposts       Repost[]
  followers     Follow[]    @relation("following")
  following     Follow[]    @relation("follower")
  mentions      Mention[]
  activities    Activity[]

  // Messaging relations
  conversationParticipants ConversationParticipant[]
  messages                 Message[]

  @@index([username])
  @@map("users")
}

/// Account model - Stores OAuth and credential account information
model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?   @db.Text
  refreshToken         String?   @db.Text
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?   @db.Text
  password             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

/// Session model - Active user sessions
model Session {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  /// Set when an admin is impersonating this session (Better Auth admin plugin)
  impersonatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// Verification model - Email verification, password reset tokens, etc.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verifications")
}

// ============================================================================
// Social Models
// ============================================================================

/// Post type — regular post or music review
enum PostType {
  POST
  REVIEW
}

/// Subject type for a review attachment
enum ReviewSubjectType {
  RELEASE
  TRACK
}

/// Visibility of a post/review
enum PostVisibility {
  PUBLIC
  PRIVATE
}

/// Profile type — categorizes users by their role/verification status
enum ProfileType {
  USER
  VOICE
  ARTIST
}

/// Post model - User-created content
model Post {
  id          String   @id @default(cuid())
  content     String         @db.Text
  contentHtml String?        @db.Text
  type        PostType       @default(POST)
  visibility  PostVisibility @default(PUBLIC)
  authorId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  likes         Like[]
  reposts       Repost[]
  mentions      Mention[]
  reviewSubject ReviewSubject?

  @@index([authorId])
  @@index([createdAt])
  @@index([type])
  @@index([visibility])
  @@map("posts")
}

/// Music entity attached to a review post
model ReviewSubject {
  id          String            @id @default(cuid())
  postId      String            @unique
  type        ReviewSubjectType
  /// Canonical identity for dedup and entity pages
  gtin        String?
  isrc        String?
  mbid        String?
  /// Denormalized display fallback
  title       String
  artistLabel String?
  artworkUrl  String?
  releaseDate String?
  /// Full harmonized snapshot (HarmonizedRelease | HarmonizedTrack)
  snapshot    Json
  createdAt   DateTime          @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([gtin])
  @@index([isrc])
  @@index([mbid])
  @@index([type])
  @@map("review_subjects")
}

/// Repost model - Reposts (reshares) of a post to a user's followers
model Repost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([createdAt])
  @@map("reposts")
}

/// Comment model - Comments on posts
model Comment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  contentHtml String?  @db.Text
  authorId    String
  postId      String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]
  mentions  Mention[]

  @@index([authorId])
  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

/// Like model - Likes on posts or comments
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@map("likes")
}

/// Follow model - User following relationships
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

/// Mention type enum for extensibility
enum MentionType {
  USER
  ARTIST // future
  ALBUM // future
  TRACK // future
}

/// Mention model - @mentions or #mentions in posts or comments
///
/// USER mentions reference a local `User` row via `userId`. Non-USER mentions
/// (ARTIST/ALBUM/TRACK) reference an external, provider-backed entity that has
/// no local table, so they're stored via `entityId` (format: "provider:id")
/// and a denormalized `entityLabel` captured at mention time instead.
model Mention {
  id          String      @id @default(cuid())
  type        MentionType @default(USER)
  userId      String?
  /// External entity reference for non-USER mentions (format: "provider:id")
  entityId    String?
  /// Denormalized display label for non-USER mentions (e.g. artist name)
  entityLabel String?
  postId      String?
  commentId   String?
  createdAt   DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([commentId])
  @@index([type])
  @@index([entityId])
  @@map("mentions")
}

/// Activity type enum for the activity feed
enum ActivityType {
  POST_CREATED
  REVIEW_CREATED
  POST_LIKED
  POST_REPOSTED
  COMMENT_CREATED
  COMMENT_LIKED
  USER_FOLLOWED
  USER_MENTIONED
}

/// Activity model - Activity feed for users
model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  userId     String
  actorId    String?
  postId     String?
  commentId  String?
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

// ============================================================================
// Messaging Models
// ============================================================================

/// Conversation model - A direct message thread between users.
/// v1 supports 1:1 conversations only; ConversationParticipant generalizes
/// to group conversations later without a schema rewrite.
model Conversation {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

/// ConversationParticipant model - Membership + per-user read state for a conversation
model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

/// Message model - A single message within a conversation
model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  contentHtml    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ============================================================================
// Configuration Models
// ============================================================================

/// Stores runtime configuration for harmony engine providers
model ProviderSetting {
  id           String   @id @default(cuid())
  providerName String   @unique @map("provider_name")
  enabled      Boolean  @default(true)
  priority     Int      @default(50)
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")


  @@map("provider_settings")
}
