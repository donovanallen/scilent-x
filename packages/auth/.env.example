# Package-local reference for @scilent-one/auth.
# When running the Next app, set these in apps/web/.env.local instead
# (validated by apps/web/src/env.ts).

# --- Required (also validated by apps/web) ------------------------------------
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scilent_x?schema=public"
# BETTER_AUTH_SECRET="your-secret-here-at-least-32-chars!!"
# BETTER_AUTH_URL="http://127.0.0.1:3000"

# Optional bootstrap: comma-separated user IDs treated as admins before seed
# BETTER_AUTH_ADMIN_USER_IDS=

# --- Optional: streaming OAuth (genericOAuth in server.ts) --------------------
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=

# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI="http://127.0.0.1:3000/api/auth/callback/spotify"

# --- Optional: social login (commented out in server.ts today) ----------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
