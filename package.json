{
  "name": "scilent-x",
  "private": true,
  "scripts": {
    "changeset": "pnpm exec changeset",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:ui": "pnpm --filter @scilent-one/ui sandbox",
    "storybook:ui": "pnpm turbo --filter=@scilent-one/ui storybook",
    "storybook:h-ui": "pnpm turbo --filter=@scilent-one/scilent-ui storybook",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "fix": "turbo lint && turbo format && turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "version": "pnpm exec changeset version",
    "release": "pnpm exec changeset publish",
    "db:generate": "pnpm --filter @scilent-one/db db:generate",
    "db:migrate": "pnpm --filter @scilent-one/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @scilent-one/db db:migrate:deploy",
    "db:push": "pnpm --filter @scilent-one/db db:push",
    "db:seed": "pnpm --filter @scilent-one/db db:seed",
    "db:studio": "pnpm --filter @scilent-one/db db:studio",
    "clean:full": "rm -rf node_modules apps/*/node_modules apps/web/.next packages/*/node_modules .turbo apps/*/.turbo packages/*/.turbo",
    "reinstall": "pnpm clean:full && pnpm install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@scilent-one/tooling": "workspace:*",
    "@turbo/gen": "^2.10.4",
    "eslint": "^10.6.0",
    "eslint-plugin-storybook": "^10.4.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
